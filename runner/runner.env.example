# RD-AISEC runner config — copy to runner.env (next to the script) or to
# ~/.config/rdaisec/runner.env. The runner loads it automatically, so you set
# these once instead of `export`-ing them every time.
#
#   cp runner.env.example runner.env   # then edit the values below
#
# Real environment variables (export ...) still override this file.

# Required
PORTAL_URL=https://rd-aisec.vercel.app
RUNNER_TOKEN=rdr_paste_your_token_here

# Optional
# MAX_WORKERS=3              # how many jobs to run at once
# PROGRESS_SECONDS=3         # live-output stream interval (0 = off)
# JOB_TIMEOUT=900            # per-job timeout (seconds)
# RUNNER_SUDO_PASS=          # local sudo password for installs (kept on this machine only)
