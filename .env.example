# ── Database (Prisma + PostgreSQL) ─────────────────────────────────────
# Use a Postgres connection string (Neon, Supabase, Vercel Postgres, or local).
# Then run `npx prisma migrate deploy` to create the tables.
# Example (Neon): postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/rdaisec"

# Direct (NON-pooled) connection — used ONLY for migrations. On Neon this is the
# same as DATABASE_URL but with "-pooler" removed from the host. Required so
# `prisma migrate deploy` can take its advisory lock (avoids the P1002 timeout).
# Example (Neon direct): postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DIRECT_URL="postgresql://user:password@localhost:5432/rdaisec"

# ── Auth.js (NextAuth v5) ──────────────────────────────────────────────
# Required. Generate one with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=

# ── OAuth providers ────────────────────────────────────────────────────
# Configure at least one. Each is auto-enabled only when both vars are set.
# GitHub:  https://github.com/settings/developers
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Google:  https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Access control ─────────────────────────────────────────────────────
# Comma-separated allowlist of emails permitted to sign in.
# Leave empty to allow any successful OAuth login (tighten this in production!).
AUTHORIZED_EMAILS=

# ── Developer login (DO NOT enable in production) ──────────────────────
# A username/password fallback so you can use the dashboard before wiring OAuth.
ALLOW_DEV_LOGIN=true
DEV_LOGIN_PASSWORD=letmein

# ── AI backend (optional — mock is used when unset) ────────────────────
# To enable the real Claude integration, install @anthropic-ai/sdk, set this,
# and follow the steps in lib/ai.ts.
# ANTHROPIC_API_KEY=
