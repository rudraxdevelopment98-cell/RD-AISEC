// RD-AISEC data model — engagements and their findings.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Neon -pooler host) for the app at runtime.
  url       = env("DATABASE_URL")
  // Direct, NON-pooled connection for migrations — pooled/PgBouncer connections
  // can't hold the advisory lock `prisma migrate deploy` needs (P1002 timeout).
  directUrl = env("DIRECT_URL")
}

// A unit of work: a pentest, forensics case, or consulting engagement.
model Engagement {
  id           String    @id @default(cuid())
  name         String
  client       String    @default("")
  // "pentest" | "forensics" | "consulting"
  type         String    @default("pentest")
  // "planning" | "active" | "completed"
  status       String    @default("planning")
  scope        String    @default("")
  authorized   Boolean   @default(false)
  authorizedBy String    @default("")
  ownerEmail   String    @default("")
  findings     Finding[]
  resources    Resource[]
  jobs         Job[]
  scans        ScanRun[]
  schedules    ScheduledScan[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// A catalog entry in the Resource Vault. The actual file lives offline (e.g. on
// an external drive) — we store only the metadata + a link or drive location.
model Resource {
  id           String      @id @default(cuid())
  title        String
  // "link" | "book" | "exploit" | "tool" | "cheatsheet" | "other"
  type         String      @default("link")
  url          String      @default("") // online resources
  location     String      @default("") // offline drive label, e.g. "SSD:/Books/nmap.pdf"
  tags         String      @default("")
  notes        String      @default("")
  ownerEmail   String      @default("")
  engagement   Engagement? @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  engagementId String?
  createdAt    DateTime    @default(now())
}

// A registered execution host (e.g. a Kali VM in UTM on an external drive).
// The portal queues Jobs; the runner polls over HTTPS, executes them locally,
// and posts results back. The token is stored hashed; the plaintext is shown
// to the user exactly once at creation.
model Runner {
  id         String    @id @default(cuid())
  name       String
  tokenHash  String    @unique
  ownerEmail String    @default("")
  lastSeenAt DateTime?
  version    String    @default("") // runner script version it reports
  toolCount  Int       @default(0)  // number of tools the runner has loaded
  anonymity  Boolean   @default(false) // desired: route tool traffic via Tor
  exitIp     String    @default("")    // Tor exit IP the runner reports when on
  subnets    String    @default("")    // comma-separated local CIDRs the runner detected
  installed  String    @default("")    // comma-separated tool ids whose binary is present
  createdAt  DateTime  @default(now())
  jobs       Job[]
  installs   Install[]
}

// A request to install a tool's package on a runner (authorized by the user).
model Install {
  id          String    @id @default(cuid())
  runner      Runner    @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  runnerId    String
  tool        String
  // "pending" | "installing" | "done" | "failed"
  status      String    @default("pending")
  output      String    @default("")
  exitCode    Int?
  requestedBy String    @default("")
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?
}

// A single tool execution queued by the portal and run by a Runner.
// engagementId is OPTIONAL: a "quick scan" (e.g. the runner's own network) has
// no engagement; engagement scans are the formal, scope-gated ones.
model Job {
  id           String      @id @default(cuid())
  engagement   Engagement? @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  engagementId String?
  runner       Runner?     @relation(fields: [runnerId], references: [id], onDelete: SetNull)
  runnerId     String?
  // allowlisted tool id, e.g. "nmap" | "nuclei" | "httpx" | "whois" | "dig"
  tool         String
  // validated target (in-scope host/URL)
  target       String
  // validated, space-separated tool flags (no shell metacharacters)
  args         String     @default("")
  // "queued" | "running" | "done" | "failed" | "canceled"
  status       String     @default("queued")
  output       String     @default("") // raw tool output (capped)
  exitCode     Int?
  queuedBy     String     @default("") // user email, for audit
  createdAt    DateTime   @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
}

// A single issue discovered during an engagement.
model Finding {
  id             String     @id @default(cuid())
  engagement     Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId   String
  title          String
  // "info" | "low" | "medium" | "high" | "critical"
  severity       String     @default("medium")
  // "open" | "fixed" | "accepted" | "false_positive"
  status         String     @default("open")
  description    String     @default("")
  recommendation String     @default("")
  // Framework tags (deterministic mapping — see lib/finding-map.ts).
  // MITRE ATT&CK tactic id (e.g. "TA0001") and OWASP Top 10 id (e.g. "A03"); "" = unmapped.
  attack         String     @default("")
  owasp          String     @default("")
  createdAt      DateTime   @default(now())
}

// A single reconnaissance/security scan run. Tracks scan execution history,
// results, and progress for trend analysis and audit trail.
model ScanRun {
  id             String     @id @default(cuid())
  engagement     Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId   String
  target         String     // URL, IP, or domain being scanned
  scanType       String     // "dns" | "port" | "web" | "posture" | "osint"
  // "pending" | "running" | "completed" | "failed"
  status         String     @default("pending")
  progress       Int        @default(0) // 0-100 percentage
  result         String     @default("{}") // JSON: parsed scan results
  error          String     @default("") // error message if failed
  durationMs     Int        @default(0) // execution time in ms
  createdAt      DateTime   @default(now())
  completedAt    DateTime? // when scan finished
}

// A recurring passive web-posture scan. The Vercel cron hits /api/cron/scan,
// which runs every enabled schedule whose interval has elapsed and saves new
// findings to its engagement (deduped against existing open findings).
model ScheduledScan {
  id           String      @id @default(cuid())
  targets      String      // newline/comma-separated URLs (<= MAX_BULK_TARGETS)
  engagement   Engagement  @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId String
  // "daily" | "weekly"
  frequency    String      @default("daily")
  enabled      Boolean     @default(true)
  ownerEmail   String      @default("")
  lastRunAt    DateTime?
  lastStatus   String      @default("") // human summary of the last run
  createdAt    DateTime    @default(now())
}
